<UserControl
  x:Class="TimeTracker.Controls.DateTimePicker"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:local="clr-namespace:TimeTracker.Controls"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  x:Name="this"
  d:DesignHeight="450"
  d:DesignWidth="800"
  DataContextChanged="this_DataContextChanged"
  mc:Ignorable="d">

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="Auto" />
      <ColumnDefinition Width="Auto" />
    </Grid.ColumnDefinitions>

    <DatePicker
      x:Name="DatePickerControl"
      Grid.Column="0"
      SelectedDate="{Binding SelectedDate, Mode=TwoWay, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type local:DateTimePicker}}}" />
    <StackPanel
      Grid.Column="1"
      Margin="5,0,0,0"
      Orientation="Horizontal">
      <ComboBox x:Name="HourComboBox" SelectedIndex="{Binding SelectedHour, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type local:DateTimePicker}}}" />
      <TextBlock Margin="5,0,5,0" Text=":" />
      <ComboBox x:Name="MinuteComboBox" SelectedIndex="{Binding SelectedMinute, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type local:DateTimePicker}}}" />
    </StackPanel>
  </Grid>
</UserControl>
