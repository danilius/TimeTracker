<UserControl
  x:Class="TimeTracker.Controls.StackedDateTimePicker"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:local="clr-namespace:TimeTracker.Controls"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  d:DesignHeight="92"
  d:DesignWidth="160"
  mc:Ignorable="d">

  <StackPanel Width="160">
    <DatePicker
      x:Name="DatePickerControl"
      Height="42"
      VerticalContentAlignment="Center"
      FontSize="15"
      SelectedDateChanged="DatePickerControl_SelectedDateChanged" />
    <ComboBox
      x:Name="TimeComboBox"
      Height="42"
      Margin="0,8,0,0"
      VerticalContentAlignment="Center"
      FontSize="15"
      IsEditable="True"
      IsTextSearchEnabled="True"
      LostFocus="TimeComboBox_LostFocus"
      SelectionChanged="TimeComboBox_SelectionChanged" />
  </StackPanel>
</UserControl>
