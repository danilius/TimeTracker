<Window
  x:Class="TimeTracker.Dialogs.NewWorkEntryDialog"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:Controls="clr-namespace:TimeTracker.Controls"
  xmlns:ViewModels="clr-namespace:TimeTracker.ViewModels"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  Title="New work entry"
  Width="720"
  Height="640"
  MinWidth="680"
  MinHeight="600"
  Loaded="Window_Loaded"
  ResizeMode="NoResize"
  WindowStartupLocation="CenterOwner"
  Background="White"
  FontFamily="Segoe UI"
  mc:Ignorable="d">

  <Window.DataContext>
    <ViewModels:NewWorkEntryModel x:Name="newWorkEntryModel" />
  </Window.DataContext>

  <Window.Resources>
    <SolidColorBrush x:Key="AccentBrush" Color="#0079E7" />
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#17212B" />
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#64707D" />
    <SolidColorBrush x:Key="BorderBrush" Color="#CBD5DF" />

    <Style x:Key="DialogLabelStyle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="Margin" Value="0,0,0,7" />
    </Style>

    <Style x:Key="DialogSmallLabelStyle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
      <Setter Property="FontSize" Value="16" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="DialogInputStyle" TargetType="Control">
      <Setter Property="Height" Value="42" />
      <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="FontSize" Value="16" />
      <Setter Property="Padding" Value="12,0" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style BasedOn="{StaticResource DialogInputStyle}" TargetType="TextBox" />
    <Style BasedOn="{StaticResource DialogInputStyle}" TargetType="ComboBox" />

    <Style x:Key="DialogButtonBaseStyle" TargetType="Button">
      <Setter Property="Height" Value="36" />
      <Setter Property="MinWidth" Value="104" />
      <Setter Property="Padding" Value="16,0" />
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="#CBD5DF" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
      <Setter Property="FontSize" Value="15" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border
              x:Name="ButtonChrome"
              Background="{TemplateBinding Background}"
              BorderBrush="{TemplateBinding BorderBrush}"
              BorderThickness="{TemplateBinding BorderThickness}"
              CornerRadius="6">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="ButtonChrome" Property="Background" Value="#EAF4FF" />
                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="#8EC7F7" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="DialogPrimaryButtonStyle" BasedOn="{StaticResource DialogButtonBaseStyle}" TargetType="Button">
      <Setter Property="Background" Value="{StaticResource AccentBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border
              x:Name="ButtonChrome"
              Background="{TemplateBinding Background}"
              BorderBrush="{TemplateBinding BorderBrush}"
              BorderThickness="{TemplateBinding BorderThickness}"
              CornerRadius="6">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="ButtonChrome" Property="Background" Value="#0B66BE" />
                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="#0B66BE" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="SmallIconButtonStyle" BasedOn="{StaticResource DialogButtonBaseStyle}" TargetType="Button">
      <Setter Property="Width" Value="42" />
      <Setter Property="MinWidth" Value="42" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="FontSize" Value="22" />
      <Setter Property="FontWeight" Value="Normal" />
    </Style>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="78" />
      <RowDefinition Height="*" />
      <RowDefinition Height="72" />
    </Grid.RowDefinitions>

    <Border
      Grid.Row="0"
      Padding="32,0"
      BorderBrush="#E4E9EF"
      BorderThickness="0,0,0,1">
      <Grid>
        <TextBlock
          x:Name="DialogTitleTextBlock"
          VerticalAlignment="Center"
          FontSize="22"
          FontWeight="SemiBold"
          Foreground="{StaticResource PrimaryTextBrush}"
          Text="New work entry" />
        <Button
          Width="36"
          Height="36"
          HorizontalAlignment="Right"
          VerticalAlignment="Center"
          Background="Transparent"
          BorderThickness="0"
          Click="CloseButton_Click"
          Content="&#xE711;"
          FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
          FontSize="14" />
      </Grid>
    </Border>

    <ScrollViewer
      Grid.Row="1"
      Padding="32,24"
      HorizontalScrollBarVisibility="Disabled"
      VerticalScrollBarVisibility="Auto">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="28" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Row="0" Grid.Column="0">
          <TextBlock Style="{StaticResource DialogLabelStyle}" Text="Client" />
          <ComboBox
            x:Name="ClientComboBox"
            DisplayMemberPath="Name"
            IsEditable="True"
            SelectionChanged="ClientComboBox_SelectionChanged"
            Text="{Binding ClientName, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>

        <StackPanel Grid.Row="0" Grid.Column="2">
          <TextBlock Style="{StaticResource DialogLabelStyle}" Text="Project" />
          <ComboBox
            x:Name="ProjectComboBox"
            DisplayMemberPath="Name"
            IsEditable="True"
            SelectionChanged="ProjectComboBox_SelectionChanged"
            Text="{Binding ProjectName, UpdateSourceTrigger=LostFocus}" />
        </StackPanel>

        <StackPanel
          Grid.Row="1"
          Grid.Column="0"
          Grid.ColumnSpan="3"
          Margin="0,28,0,0">
          <TextBlock Style="{StaticResource DialogLabelStyle}" Text="Description" />
          <TextBox
            x:Name="DescriptionTextBox"
            Height="42"
            AcceptsReturn="False"
            Text="{Binding Description}"
            TextWrapping="NoWrap" />
        </StackPanel>

        <Grid
          Grid.Row="2"
          Grid.Column="0"
          Grid.ColumnSpan="3"
          Margin="0,28,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="28" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="28" />
            <ColumnDefinition Width="180" />
          </Grid.ColumnDefinitions>

          <StackPanel Grid.Column="0">
            <TextBlock Style="{StaticResource DialogLabelStyle}" Text="Start" />
            <Controls:DateTimePicker x:Name="StartTimePicker" SelectedDate="{Binding StartTime}" />
          </StackPanel>

          <StackPanel Grid.Column="2">
            <TextBlock Style="{StaticResource DialogLabelStyle}" Text="Duration" />
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="76" />
                <ColumnDefinition Width="34" />
                <ColumnDefinition Width="76" />
                <ColumnDefinition Width="34" />
              </Grid.ColumnDefinitions>
              <TextBox
                x:Name="DurationHoursTextBox"
                Grid.Column="0"
                PreviewTextInput="WholeNumberTextBox_PreviewTextInput" />
              <TextBlock
                Grid.Column="1"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Style="{StaticResource DialogSmallLabelStyle}"
                Text="h" />
              <TextBox
                x:Name="DurationMinutesTextBox"
                Grid.Column="2"
                PreviewTextInput="WholeNumberTextBox_PreviewTextInput" />
              <TextBlock
                Grid.Column="3"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Style="{StaticResource DialogSmallLabelStyle}"
                Text="m" />
            </Grid>
          </StackPanel>
        </Grid>

        <Grid
          Grid.Row="3"
          Grid.Column="0"
          Grid.ColumnSpan="3"
          Margin="0,28,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160" />
            <ColumnDefinition Width="28" />
            <ColumnDefinition Width="90" />
          </Grid.ColumnDefinitions>

          <StackPanel Grid.Column="0">
            <TextBlock Style="{StaticResource DialogLabelStyle}" Text="Hourly rate" />
            <TextBox
              x:Name="HourlyRateTextBox"
              PreviewTextInput="DecimalTextBox_PreviewTextInput" />
          </StackPanel>

          <StackPanel Grid.Column="2">
            <TextBlock Style="{StaticResource DialogLabelStyle}" Text="Currency" />
            <ComboBox
              x:Name="CurrencyComboBox"
              Width="72"
              HorizontalAlignment="Left"
              IsEditable="True"
              IsTextSearchEnabled="True" />
          </StackPanel>
        </Grid>

      </Grid>
    </ScrollViewer>

    <Border
      Grid.Row="2"
      Padding="32,0"
      BorderBrush="#E4E9EF"
      BorderThickness="0,1,0,0">
      <Grid>
        <Button
          x:Name="CancelButton"
          HorizontalAlignment="Left"
          VerticalAlignment="Center"
          Content="Cancel"
          IsCancel="True"
          Style="{StaticResource DialogButtonBaseStyle}" />
        <StackPanel
          HorizontalAlignment="Right"
          VerticalAlignment="Center"
          Orientation="Horizontal">
          <Button
            x:Name="SaveEntryButton"
            Margin="0,0,12,0"
            Click="StartButton_Click"
            Content="Save entry"
            IsDefault="True"
            Style="{StaticResource DialogButtonBaseStyle}" />
          <Button
            x:Name="StartButton"
            MinWidth="132"
            Click="StartButton_Click"
            Content="Save and start"
            Style="{StaticResource DialogPrimaryButtonStyle}" />
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>
