<Window
  x:Class="TimeTracker.Dialogs.NewWorkEntryDialog"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:Controls="clr-namespace:TimeTracker.Controls"
  xmlns:ViewModels="clr-namespace:TimeTracker.ViewModels"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  Title="New work entry"
  Width="780"
  Height="700"
  MinWidth="740"
  MinHeight="660"
  Loaded="Window_Loaded"
  ResizeMode="NoResize"
  WindowStartupLocation="CenterOwner"
  Background="White"
  FontFamily="Segoe UI"
  mc:Ignorable="d">

  <Window.DataContext>
    <ViewModels:NewWorkEntryModel x:Name="newWorkEntryModel" />
  </Window.DataContext>

  <Window.Resources>
    <SolidColorBrush x:Key="AccentBrush" Color="#0079E7" />
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#17212B" />
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#64707D" />
    <SolidColorBrush x:Key="BorderBrush" Color="#CBD5DF" />
    <SolidColorBrush x:Key="LockedFieldBrush" Color="#EEF2F6" />

    <Style x:Key="DialogLabelStyle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="Margin" Value="0,0,0,7" />
    </Style>

    <Style x:Key="DialogSmallLabelStyle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
      <Setter Property="FontSize" Value="16" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="DialogInputStyle" TargetType="Control">
      <Setter Property="Height" Value="42" />
      <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="FontSize" Value="16" />
      <Setter Property="Padding" Value="12,0" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style BasedOn="{StaticResource DialogInputStyle}" TargetType="TextBox" />
    <Style BasedOn="{StaticResource DialogInputStyle}" TargetType="ComboBox" />

    <Style x:Key="DialogButtonBaseStyle" TargetType="Button">
      <Setter Property="Height" Value="36" />
      <Setter Property="MinWidth" Value="104" />
      <Setter Property="Padding" Value="16,0" />
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="#CBD5DF" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
      <Setter Property="FontSize" Value="15" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border
              x:Name="ButtonChrome"
              Background="{TemplateBinding Background}"
              BorderBrush="{TemplateBinding BorderBrush}"
              BorderThickness="{TemplateBinding BorderThickness}"
              CornerRadius="6">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="ButtonChrome" Property="Background" Value="#EAF4FF" />
                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="#8EC7F7" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="DialogPrimaryButtonStyle" BasedOn="{StaticResource DialogButtonBaseStyle}" TargetType="Button">
      <Setter Property="Background" Value="{StaticResource AccentBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border
              x:Name="ButtonChrome"
              Background="{TemplateBinding Background}"
              BorderBrush="{TemplateBinding BorderBrush}"
              BorderThickness="{TemplateBinding BorderThickness}"
              CornerRadius="6">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="ButtonChrome" Property="Background" Value="#0B66BE" />
                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="#0B66BE" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="StepperButtonStyle" TargetType="Button">
      <Setter Property="Background" Value="#F5F7FA" />
      <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
      <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets" />
      <Setter Property="FontSize" Value="8" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border
              x:Name="StepperChrome"
              Background="{TemplateBinding Background}"
              BorderBrush="{TemplateBinding BorderBrush}"
              BorderThickness="{TemplateBinding BorderThickness}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="StepperChrome" Property="Background" Value="#EAF4FF" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!--  Pill-style on/off switch used by the Billable field  -->
    <Style x:Key="SwitchToggleStyle" TargetType="ToggleButton">
      <Setter Property="Width" Value="52" />
      <Setter Property="Height" Value="28" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ToggleButton">
            <Border
              x:Name="SwitchTrack"
              Background="#C4CDD7"
              CornerRadius="14">
              <Ellipse
                x:Name="SwitchThumb"
                Width="22"
                Height="22"
                Margin="3,0,0,0"
                HorizontalAlignment="Left"
                Fill="White" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="SwitchTrack" Property="Background" Value="#2FB457" />
                <Setter TargetName="SwitchThumb" Property="HorizontalAlignment" Value="Right" />
                <Setter TargetName="SwitchThumb" Property="Margin" Value="0,0,3,0" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="78" />
      <RowDefinition Height="*" />
      <RowDefinition Height="72" />
    </Grid.RowDefinitions>

    <Border
      Grid.Row="0"
      Padding="32,0"
      BorderBrush="#E4E9EF"
      BorderThickness="0,0,0,1">
      <Grid>
        <TextBlock
          x:Name="DialogTitleTextBlock"
          VerticalAlignment="Center"
          FontSize="22"
          FontWeight="SemiBold"
          Foreground="{StaticResource PrimaryTextBrush}"
          Text="New work entry" />
      </Grid>
    </Border>

    <ScrollViewer
      Grid.Row="1"
      Padding="32,24"
      HorizontalScrollBarVisibility="Disabled"
      VerticalScrollBarVisibility="Auto">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="28" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  Client  -->
        <StackPanel Grid.Row="0" Grid.Column="0">
          <TextBlock Style="{StaticResource DialogLabelStyle}" Text="Client" />
          <ComboBox
            x:Name="ClientComboBox"
            DisplayMemberPath="Name"
            IsEditable="True"
            SelectionChanged="ClientComboBox_SelectionChanged"
            TextBoxBase.TextChanged="ClientComboBox_TextChanged"
            Text="{Binding ClientName, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>

        <!--  Project  -->
        <StackPanel Grid.Row="0" Grid.Column="2">
          <TextBlock Style="{StaticResource DialogLabelStyle}" Text="Project" />
          <ComboBox
            x:Name="ProjectComboBox"
            DisplayMemberPath="Name"
            IsEditable="True"
            Text="{Binding ProjectName, UpdateSourceTrigger=LostFocus}" />
        </StackPanel>

        <!--  Description  -->
        <StackPanel
          Grid.Row="1"
          Grid.Column="0"
          Grid.ColumnSpan="3"
          Margin="0,24,0,0">
          <TextBlock Style="{StaticResource DialogLabelStyle}" Text="Description" />
          <TextBox
            x:Name="DescriptionTextBox"
            Height="42"
            AcceptsReturn="False"
            Text="{Binding Description}"
            TextWrapping="NoWrap" />
        </StackPanel>

        <!--  Start / End / Duration  -->
        <Grid
          Grid.Row="2"
          Grid.Column="0"
          Grid.ColumnSpan="3"
          Margin="0,24,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="24" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="24" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <StackPanel Grid.Column="0">
            <TextBlock Style="{StaticResource DialogLabelStyle}" Text="Start" />
            <Controls:StackedDateTimePicker x:Name="StartTimePicker" SelectedDate="{Binding StartTime}" />
          </StackPanel>

          <StackPanel Grid.Column="2">
            <TextBlock Style="{StaticResource DialogLabelStyle}" Text="End" />
            <Controls:StackedDateTimePicker x:Name="EndTimePicker" SelectedDate="{Binding EndTime}" />
          </StackPanel>

          <StackPanel Grid.Column="4" VerticalAlignment="Top">
            <TextBlock Style="{StaticResource DialogLabelStyle}" Text="Duration" />
            <Border
              Width="140"
              Height="42"
              HorizontalAlignment="Left"
              Background="{StaticResource LockedFieldBrush}"
              BorderBrush="{StaticResource BorderBrush}"
              BorderThickness="1"
              CornerRadius="2">
              <Grid Margin="12,0">
                <TextBlock
                  x:Name="DurationDisplayText"
                  VerticalAlignment="Center"
                  FontSize="16"
                  Foreground="{StaticResource PrimaryTextBrush}"
                  Text="0m" />
                <TextBlock
                  HorizontalAlignment="Right"
                  VerticalAlignment="Center"
                  FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                  FontSize="14"
                  Foreground="{StaticResource SecondaryTextBrush}"
                  Text="&#xE72E;"
                  ToolTip="Duration is calculated from Start and End" />
              </Grid>
            </Border>
          </StackPanel>
        </Grid>

        <!--  Billable / Hourly rate / Currency  -->
        <Grid
          Grid.Row="3"
          Grid.Column="0"
          Grid.ColumnSpan="3"
          Margin="0,24,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120" />
            <ColumnDefinition Width="28" />
            <ColumnDefinition Width="180" />
            <ColumnDefinition Width="28" />
            <ColumnDefinition Width="120" />
          </Grid.ColumnDefinitions>

          <StackPanel Grid.Column="0">
            <TextBlock Style="{StaticResource DialogLabelStyle}" Text="Billable" />
            <ToggleButton
              x:Name="BillableToggle"
              HorizontalAlignment="Left"
              IsChecked="True"
              Style="{StaticResource SwitchToggleStyle}" />
          </StackPanel>

          <StackPanel Grid.Column="2">
            <TextBlock Style="{StaticResource DialogLabelStyle}" Text="Hourly rate" />
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="22" />
              </Grid.ColumnDefinitions>
              <TextBox
                x:Name="HourlyRateTextBox"
                Grid.Column="0"
                PreviewTextInput="DecimalTextBox_PreviewTextInput" />
              <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                  <RowDefinition Height="*" />
                  <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Button
                  Grid.Row="0"
                  Click="RateUpButton_Click"
                  Content="&#xE70E;"
                  Style="{StaticResource StepperButtonStyle}" />
                <Button
                  Grid.Row="1"
                  Click="RateDownButton_Click"
                  Content="&#xE70D;"
                  Style="{StaticResource StepperButtonStyle}" />
              </Grid>
            </Grid>
          </StackPanel>

          <StackPanel Grid.Column="4">
            <TextBlock Style="{StaticResource DialogLabelStyle}" Text="Currency" />
            <ComboBox
              x:Name="CurrencyComboBox"
              HorizontalAlignment="Stretch"
              IsEditable="True"
              IsTextSearchEnabled="True" />
          </StackPanel>
        </Grid>

        <!--  Start timer now  -->
        <CheckBox
          x:Name="StartTimerNowCheckBox"
          Grid.Row="4"
          Grid.Column="0"
          Grid.ColumnSpan="3"
          Margin="0,24,0,0"
          VerticalContentAlignment="Center"
          Checked="StartTimerNowCheckBox_Changed"
          Unchecked="StartTimerNowCheckBox_Changed"
          FontSize="14"
          Foreground="{StaticResource PrimaryTextBrush}">
          <TextBlock Margin="6,0,0,0" VerticalAlignment="Center" Text="Start timer now" />
        </CheckBox>

      </Grid>
    </ScrollViewer>

    <Border
      Grid.Row="2"
      Padding="32,0"
      BorderBrush="#E4E9EF"
      BorderThickness="0,1,0,0">
      <Grid>
        <Button
          x:Name="CancelButton"
          HorizontalAlignment="Left"
          VerticalAlignment="Center"
          Content="Cancel"
          IsCancel="True"
          Style="{StaticResource DialogButtonBaseStyle}" />
        <StackPanel
          HorizontalAlignment="Right"
          VerticalAlignment="Center"
          Orientation="Horizontal">
          <Button
            x:Name="SaveEntryButton"
            Margin="0,0,12,0"
            Click="StartButton_Click"
            Content="Save entry"
            IsDefault="True"
            Style="{StaticResource DialogButtonBaseStyle}" />
          <Button
            x:Name="StartButton"
            MinWidth="132"
            Click="StartButton_Click"
            Content="Save and start"
            Style="{StaticResource DialogPrimaryButtonStyle}" />
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>
