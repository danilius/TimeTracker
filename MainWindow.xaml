<Window
  x:Class="TimeTracker.MainWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:XamlControls="using:Windows.UI.Xaml.Controls"
  xmlns:controls="clr-namespace:TimeTracker.Controls"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:local="clr-namespace:TimeTracker"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:models="clr-namespace:TimeTracker.Models"
  Title="MainWindow"
  Width="800"
  Height="450"
  Closing="Window_Closing"
  mc:Ignorable="d">

  


  <Window.Resources>
    <Style x:Key="NavBarIconButtonStyle" TargetType="Button">
      <Setter Property="Background" Value="Black" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
      <Setter Property="FontSize" Value="22" />
      <Setter Property="FontWeight" Value="ExtraLight" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="Black" />
                <Setter Property="Foreground" Value="#0090EE" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="NavBarButtonStyle" TargetType="Button">
      <Setter Property="Background" Value="Black" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="FontSize" Value="22" />
      <Setter Property="FontWeight" Value="Light" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}">
              <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="Black" />
                <Setter Property="Foreground" Value="#0090EE" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <!--  main grid  -->
  <Grid x:Name="MainGrid">
    <Grid.ColumnDefinitions>
      <ColumnDefinition x:Name="NavColumn" Width="200" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <!--  navbar  -->
    <Rectangle Grid.Column="0" Fill="Black" />
    <Rectangle
      Grid.Column="0"
      Width="2"
      HorizontalAlignment="Right"
      Fill="#0090EE" />
    <Grid
      x:Name="NavBarGrid"
      Grid.Column="0"
      VerticalAlignment="Top">
      <Grid.RowDefinitions>
        <RowDefinition Height="50" />
        <RowDefinition Height="50" />
        <RowDefinition Height="50" />
        <RowDefinition Height="50" />
        <RowDefinition Height="50" />
        <RowDefinition Height="50" />
        <RowDefinition Height="50" />
        <RowDefinition Height="50" />
        <RowDefinition Height="50" />
        <RowDefinition Height="50" />
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="50" />
        <ColumnDefinition />
      </Grid.ColumnDefinitions>
      <Button
        x:Name="HamburgerButton"
        Grid.Row="0"
        Grid.Column="0"
        Margin="0,0,0,0"
        HorizontalAlignment="Center"
        Click="HamburgerButton_Click"
        Content="&#xE700;"
        FontSize="22"
        Foreground="White"
        Style="{StaticResource NavBarIconButtonStyle}" />
      <Button
        Grid.Row="1"
        Grid.Column="0"
        Click="JobsButton_Click"
        Content="&#xE821;"
        Style="{StaticResource NavBarIconButtonStyle}" />
      <Button
        x:Name="JobsLabelButton"
        Grid.Row="1"
        Grid.Column="1"
        HorizontalAlignment="Left"
        Click="JobsButton_Click"
        Content="Jobs"
        Style="{StaticResource NavBarButtonStyle}" />
      <Button
        Grid.Row="2"
        Grid.Column="0"
        Click="ClientsButton_Click"
        Content="&#xE716;"
        Style="{StaticResource NavBarIconButtonStyle}" />
      <Button
        x:Name="ClientsLabelButton"
        Grid.Row="2"
        Grid.Column="1"
        HorizontalAlignment="Left"
        Click="ClientsButton_Click"
        Content="Clients"
        Style="{StaticResource NavBarButtonStyle}" />
      <Button
        Grid.Row="3"
        Grid.Column="0"
        Click="ProjectsButton_Click"
        Content="&#xE7C4;"
        Style="{StaticResource NavBarIconButtonStyle}" />
      <Button
        x:Name="ProjectsLabelButton"
        Grid.Row="3"
        Grid.Column="1"
        HorizontalAlignment="Left"
        Click="ProjectsButton_Click"
        Content="Projects"
        Style="{StaticResource NavBarButtonStyle}" />
      <Button
        Grid.Row="4"
        Grid.Column="0"
        Click="TimesheetsButton_Click"
        Content="&#xEC92;"
        Style="{StaticResource NavBarIconButtonStyle}" />
      <Button
        x:Name="TimesheetsLabelButton"
        Grid.Row="4"
        Grid.Column="1"
        HorizontalAlignment="Left"
        Click="TimesheetsButton_Click"
        Content="Time sheets"
        Style="{StaticResource NavBarButtonStyle}" />
      <Button
        Grid.Row="5"
        Grid.Column="0"
        Click="ReportsButton_Click"
        Content="&#xE9D2;"
        Style="{StaticResource NavBarIconButtonStyle}" />
      <Button
        x:Name="ReportsLabelButton"
        Grid.Row="5"
        Grid.Column="1"
        HorizontalAlignment="Left"
        Click="ReportsButton_Click"
        Content="Reports"
        Style="{StaticResource NavBarButtonStyle}" />
      <Button
        Grid.Row="6"
        Grid.Column="0"
        Click="InvoicesButton_Click"
        Content="&#xE8A5;"
        Style="{StaticResource NavBarIconButtonStyle}" />
      <Button
        x:Name="InvoicesLabelButton"
        Grid.Row="6"
        Grid.Column="1"
        HorizontalAlignment="Left"
        Click="InvoicesButton_Click"
        Content="Invoices"
        Style="{StaticResource NavBarButtonStyle}" />
      <Button
        Grid.Row="7"
        Grid.Column="0"
        Click="ArchiveButton_Click"
        Content="&#xE8B7;"
        Style="{StaticResource NavBarIconButtonStyle}" />
      <Button
        x:Name="ArchiveLabelButton"
        Grid.Row="7"
        Grid.Column="1"
        HorizontalAlignment="Left"
        Click="ArchiveButton_Click"
        Content="Archive"
        Style="{StaticResource NavBarButtonStyle}" />
      <Button
        Grid.Row="9"
        Grid.Column="0"
        Content="&#xE713;"
        Style="{StaticResource NavBarIconButtonStyle}" />
      <Button
        Grid.Row="9"
        Grid.Column="1"
        x:Name="SettingsLabelButton"
        HorizontalAlignment="Left"
        Click="SettingsButton_Click"
        Content="Settings"
        Style="{StaticResource NavBarButtonStyle}" />
    </Grid>
    <!--  end of navbar  -->

    <!--  header grid  -->
    <Grid
      Grid.Column="1"
      Height="50"
      VerticalAlignment="Top"
      Background="Black">
      <Grid.ColumnDefinitions>
        <ColumnDefinition />
        <ColumnDefinition Width="150" />
      </Grid.ColumnDefinitions>
      <Label
        x:Name="HeaderLabel"
        Grid.Column="0"
        Margin="10,0,0,0"
        d:Content="Header Label"
        FontSize="28"
        FontWeight="Light"
        Foreground="White" />
      <Button
        x:Name="StartStopButton"
        Grid.Column="1"
        Margin="5"
        Background="#00AA00"
        Click="StartStopButton_Click"
        Content="Start"
        FontSize="24"
        Foreground="White" />
    </Grid>
    <!--  end of header grid  -->

    <!--  content  -->
    <Grid
      x:Name="mainContentGrid"
      Grid.Column="1"
      Margin="0,50,0,0">
      <ScrollViewer>
        <controls:WorkEntriesListControl x:Name="workEntriesListControl" />
      </ScrollViewer>
    </Grid>
    <!--  end of content  -->

  </Grid>
  <!--  end of main grid  -->
</Window>
